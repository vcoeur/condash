# Track all images + PDFs anywhere under projects/ in git-lfs.
# /projects worktree status / /knowledge verify run an audit that flags
# any uncovered binary > 50 kB.
projects/**/*.pdf filter=lfs diff=lfs merge=lfs -text
projects/**/*.png filter=lfs diff=lfs merge=lfs -text
projects/**/*.jpg filter=lfs diff=lfs merge=lfs -text
projects/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
