# Sentinels: signal that the matching index tree is stale. /projects index
# and /knowledge index clear them. Never commit.
projects/.index-dirty
knowledge/.index-dirty

# Per-item scratch directory next to notes/ — raw inputs, intermediate
# renders, generator scripts. Deliverables live under notes/, not here.
projects/*/*/local/
projects/*/*/local/**

# Local Claude scratch files. Global gitignore convention is **/.claude/*.local.*
.claude/*.local.*

# condash workspace state (per-host: settings.json + terminal logs).
# Note: ignoring the dir contents with `.condash/*` (not the dir itself)
# is what lets the negation re-include the starter example. A bare
# `.condash/` would shadow every nested path beyond git's reach.
.condash/*
!.condash/settings.json.example

# Common OS / editor cruft.
.DS_Store
Thumbs.db
*.swp
*.swo
