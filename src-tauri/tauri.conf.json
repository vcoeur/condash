{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "condash",
  "version": "0.20.1",
  "identifier": "com.vcoeur.condash",
  "build": {
    "frontendDist": "../src/condash/assets"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Conception Dashboard",
        "url": "dashboard.html",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Conception dashboard",
    "longDescription": "Standalone desktop dashboard for markdown-based conception items. Tauri port (Phase 0)."
  }
}
