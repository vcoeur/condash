{
  "name": "condash",
  "version": "2.10.14",
  "description": "Markdown project dashboard for the conception tree (Electron build)",
  "private": true,
  "main": "dist-electron/main/index.js",
  "bin": {
    "condash": "dist-cli/condash.cjs"
  },
  "homepage": "https://github.com/vcoeur/condash",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vcoeur/condash.git"
  },
  "bugs": "https://github.com/vcoeur/condash/issues",
  "author": {
    "name": "Alice Voland",
    "email": "alice@vcoeur.com"
  },
  "license": "MIT",
  "scripts": {
    "dev:main": "node scripts/build-electron.mjs --watch",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5600 && wait-on dist-electron/main/index.js && ELECTRON_OZONE_PLATFORM_HINT=wayland electron --no-sandbox . 2>&1 | grep --line-buffered -vE 'GdkPixbuf-(CRITICAL|WARNING)|GetVSyncParametersIfAvailable\\(\\) failed' || true",
    "dev": "node scripts/build-electron.mjs --dev && concurrently -k -n main,renderer,electron -c blue,green,magenta \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build:main": "node scripts/build-electron.mjs",
    "build:renderer": "vite build",
    "build:cli": "node scripts/build-cli.mjs",
    "build": "npm run build:main && npm run build:renderer && npm run build:cli",
    "start": "electron .",
    "package": "npm run build && electron-builder",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html,json}\"",
    "test": "playwright test",
    "test:unit": "vitest run",
    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@xterm/addon-clipboard": "0.3.0-beta.207",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "0.10.0-beta.207",
    "@xterm/addon-ligatures": "0.11.0-beta.207",
    "@xterm/addon-search": "0.17.0-beta.207",
    "@xterm/addon-serialize": "0.15.0-beta.207",
    "@xterm/addon-unicode11": "0.10.0-beta.207",
    "@xterm/addon-web-links": "0.13.0-beta.207",
    "@xterm/addon-webgl": "0.20.0-beta.206",
    "@xterm/xterm": "6.1.0-beta.207",
    "chokidar": "^4.0.3",
    "electron-updater": "^6.6.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.14.0",
    "node-pty": "^1.1.0",
    "simple-git": "^3.36.0",
    "solid-js": "^1.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@playwright/test": "^1.59.1",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-anchor": "^7.0.0",
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^2.1.9",
    "wait-on": "^8.0.1"
  }
}
